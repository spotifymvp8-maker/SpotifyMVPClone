# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spotify_clone

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OAuth (Google, GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000

# JWT Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin emails (comma-separated). Только они могут создавать/редактировать треки.
# Добавьте test@example.com для доступа к админ-панели после seed.
ADMIN_EMAILS=test@example.com,admin@example.com

# Recommendation Service: TTL кэша в секундах (0 = без кэша)
RECOMMENDATION_CACHE_TTL=300
